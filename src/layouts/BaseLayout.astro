---
import SEO from "../components/astro/SEO.astro";
import Header from "../components/astro/Header.astro";
import Footer from "../components/astro/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" data-site-lang="en">
  <head>
    <SEO title={title} description={description} image={image} />

    <!-- Preload primary font weights -->
    <link
      rel="preload"
      href="/fonts/GeistSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/InstrumentSerif-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- EN body font: Fraunces via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400&display=swap" rel="stylesheet" />

    <!-- ZH body font fallback for Safari (which blocks system STKaiti / Kaiti SC):
         AR PL UKai — Arphic open-source classic 楷体 (Adobe Kaiti / 教科书楷体 feel).
         Chrome on Mac and any browser on Windows hit system Kaiti first via the CSS
         cascade and never trigger this download. Safari Mac falls through to AR PL UKai
         (4.6MB TTF, 1y CDN cache). font-display: swap → no FOIT. -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style>
      @font-face {
        font-family: 'AR PL UKai';
        font-display: swap;
        src: url('https://cdn.jsdelivr.net/npm/@fontpkg/ar-pl-kaiti-m-gb@2.11.0/gkai00mp.ttf') format('truetype');
      }
    </style>

    <!-- Theme & language init: runs synchronously before first paint to prevent FOUC -->
    <script is:inline>
      (function () {
        // Theme
        var stored = localStorage.getItem("theme");
        var preferred = stored
          ? stored
          : window.matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
        document.documentElement.setAttribute("data-theme", preferred);
        // Language
        var lang = localStorage.getItem("lang") || "en";
        document.documentElement.setAttribute("data-site-lang", lang);
        document.documentElement.setAttribute("lang", lang === "zh" ? "zh-CN" : "en");
        // Block Framer Motion's scroll restoration during hydration.
        // FM's AnimatePresence calls window.scrollTo(0, suspendedScrollY)
        // on mount, which scrolls to a stale position on page refresh.
        var realScrollTo = window.scrollTo.bind(window);
        window.scrollTo = function () {};
        window.addEventListener("load", function () {
          realScrollTo(0, 0);
          window.scrollTo = realScrollTo;
        });
      })();
    </script>
  </head>
  <body class="min-h-screen" style="background-color: var(--color-surface-primary);">
    <Header />
    <main class="pt-20">
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal: fade-up elements become visible on scroll -->
    <script is:inline>
      (function () {
        var obs = new IntersectionObserver(function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              entries[i].target.classList.add("visible");
              obs.unobserve(entries[i].target);
            }
          }
        }, { threshold: 0.15 });
        document.querySelectorAll(".fade-up").forEach(function (el) { obs.observe(el); });
      })();
    </script>

    <!-- Click spark effect -->
    <canvas id="click-spark-canvas" style="position:fixed;inset:0;z-index:9999;pointer-events:none;width:100%;height:100%;" aria-hidden="true"></canvas>
    <script is:inline>
      (function () {
        var canvas = document.getElementById("click-spark-canvas");
        if (!canvas) return;
        var ctx = canvas.getContext("2d");
        var sparks = [];
        var sparkSize = 16, sparkRadius = 25, sparkCount = 10, duration = 500;
        var raf;

        function resizeCanvas() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }
        window.addEventListener("resize", resizeCanvas);
        resizeCanvas();

        function ease(t) { return t * (2 - t); }

        function draw(ts) {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          sparks = sparks.filter(function (s) {
            var elapsed = ts - s.t;
            if (elapsed >= duration) return false;
            var p = ease(elapsed / duration);
            var dist = p * sparkRadius;
            var len = sparkSize * (1 - p);
            var x1 = s.x + dist * Math.cos(s.a);
            var y1 = s.y + dist * Math.sin(s.a);
            var x2 = s.x + (dist + len) * Math.cos(s.a);
            var y2 = s.y + (dist + len) * Math.sin(s.a);
            var isDark = document.documentElement.getAttribute("data-theme") !== "light";
            ctx.strokeStyle = isDark ? "rgba(255,255,255,0.95)" : "rgba(60,60,60,0.8)";
            ctx.lineWidth = 2.5;
            ctx.beginPath();
            ctx.moveTo(x1, y1);
            ctx.lineTo(x2, y2);
            ctx.stroke();
            return true;
          });
          raf = requestAnimationFrame(draw);
        }
        raf = requestAnimationFrame(draw);

        document.addEventListener("click", function (e) {
          var now = performance.now();
          for (var i = 0; i < sparkCount; i++) {
            sparks.push({ x: e.clientX, y: e.clientY, a: (2 * Math.PI * i) / sparkCount, t: now });
          }
        });
      })();
    </script>
  </body>
</html>
