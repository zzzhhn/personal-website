ke='url(%23pg)' stroke-width='1.3' fill='none'/%3E %3Cpath d='M95,120 Q92,142 90,158 Q88,168 92,155 Q95,140 98,128' stroke='url(%23pg)' stroke-width='1' fill='none'/%3E %3Cpath d='M88,115 Q82,118 78,115 M82,118 Q80,122 78,120' stroke='url(%23pg)' stroke-width='0.8' fill='none'/%3E %3Cpath d='M102,115 Q108,118 112,115 M108,118 Q110,122 112,120' stroke='url(%23pg)' stroke-width='0.8' fill='none'/%3E %3Cpath d='M30,208 Q45,202 70,205 L100,208 L130,205 Q155,202 170,208 L165,218 Q155,214 130,216 L100,220 L70,216 Q45,214 35,218 Z' stroke='url(%23pg)' stroke-width='1.2' fill='url(%23pg)' fill-opacity='0.04'/%3E %3Cpath d='M30,208 L22,203 L28,213 L35,218' stroke='url(%23pg)' stroke-width='1' fill='none'/%3E %3Cpath d='M170,208 L178,203 L172,213 L165,218' stroke='url(%23pg)' stroke-width='1' fill='none'/%3E %3Ctext x='68' y='215' font-family='serif' font-size='11' fill='url(%23pg)' text-anchor='middle'%3E博%3C/text%3E %3Ctext x='88' y='215' font-family='serif' font-size='11' fill='url(%23pg)' text-anchor='middle'%3E文%3C/text%3E %3Ctext x='112' y='215' font-family='serif' font-size='11' fill='url(%23pg)' text-anchor='middle'%3E約%3C/text%3E %3Ctext x='132' y='215' font-family='serif' font-size='11' fill='url(%23pg)' text-anchor='middle'%3E禮%3C/text%3E %3C/svg%3E");
}
