---
import { UI } from "../../lib/i18n";
import SectionHeading from "./SectionHeading.astro";
import AwardsGrid from "../react/AwardsGrid";
---

<section class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
  <div class="mx-auto" style="max-width: var(--max-width-content);">
    <SectionHeading variant="editorial" number="02" titleEn={UI.sections.education.en} titleZh={UI.sections.education.zh} />

    <!-- Education card — Approach B: tinted glass -->
    <div class="glass-tinted p-8 mb-8 mx-auto" data-foil="cuhk" style="max-width: 48rem;">
      <div class="flex items-start justify-between gap-4 flex-wrap mb-4">
        <div>
          <h3 class="text-lg font-semibold" style="color: var(--color-text-primary);">
            <span data-lang="en">{UI.education.school.en}</span>
            <span data-lang="zh">{UI.education.school.zh}</span>
          </h3>
          <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
            <span data-lang="en">{UI.education.degree.en}</span>
            <span data-lang="zh">{UI.education.degree.zh}</span>
          </p>
        </div>
        <span class="glass-subtle px-3 py-1 text-xs font-medium" style="color: var(--color-text-secondary);">
          <span data-lang="en">{UI.education.period.en}</span>
          <span data-lang="zh">{UI.education.period.zh}</span>
        </span>
      </div>

      <!-- Course scrollbar -->
      <div class="mt-5 pt-4" style="border-top: 1px solid var(--color-border-subtle);">
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-uni-gold);">
          <span data-lang="en">Key Courses</span>
          <span data-lang="zh">核心课程</span>
        </h4>
        <div class="course-scroll">
          <div data-lang="en" class="course-scroll-inner">
            {UI.education.courses.en.map((c) => (
              <span class="course-chip">{c}</span>
            ))}
          </div>
          <div data-lang="zh" class="course-scroll-inner">
            {UI.education.courses.zh.map((c) => (
              <span class="course-chip">{c}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Awards — React island with hover preview -->
    <div data-lang="en" class="mb-8">
      <AwardsGrid client:visible awards={UI.education.awards.en} />
    </div>
    <div data-lang="zh" class="mb-8">
      <AwardsGrid client:visible awards={UI.education.awards.zh} />
    </div>

    <!-- Certificates & Languages in a 2-column glass panel -->
    <div class="card-outline p-8 mx-auto" style="max-width: 48rem;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Certificates -->
        <div>
          <div data-lang="en">
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">Certificates</h3>
            <div class="space-y-3">
              {UI.education.certificates.en.map((cert) => (
                <div class="flex items-start gap-2">
                  <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                  <span class="text-sm" style="color: var(--color-text-secondary);">{cert}</span>
                </div>
              ))}
            </div>
          </div>
          <div data-lang="zh">
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">证书</h3>
            <div class="space-y-3">
              {UI.education.certificates.zh.map((cert) => (
                <div class="flex items-start gap-2">
                  <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                  <span class="text-sm" style="color: var(--color-text-secondary);">{cert}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Languages -->
        <div>
          <div data-lang="en">
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">Languages</h3>
            <div class="space-y-3">
              {UI.education.languages.en.map((lang) => (
                <div class="flex items-start gap-2">
                  <span class="text-sm font-medium flex-shrink-0" style="color: var(--color-text-primary); min-width: 5rem;">{lang.name}</span>
                  <span class="text-sm" style="color: var(--color-text-secondary);">{lang.level}</span>
                </div>
              ))}
            </div>
          </div>
          <div data-lang="zh">
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">语言能力</h3>
            <div class="space-y-3">
              {UI.education.languages.zh.map((lang) => (
                <div class="flex items-start gap-2">
                  <span class="text-sm font-medium flex-shrink-0" style="color: var(--color-text-primary); min-width: 4rem;">{lang.name}</span>
                  <span class="text-sm" style="color: var(--color-text-secondary);">{lang.level}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .course-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border-subtle) transparent;
    padding-bottom: 0.5rem;
  }
  .course-scroll::-webkit-scrollbar {
    height: 4px;
  }
  .course-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border-subtle);
    border-radius: 4px;
  }
  .course-scroll-inner {
    display: flex;
    gap: 0.5rem;
    width: max-content;
  }
  .course-chip {
    white-space: nowrap;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .course-chip:hover {
    border-color: var(--color-uni-gold);
    color: var(--color-uni-gold);
  }
</style>

<style is:global>
