  content: "";
  position: absolute;
  inset: -30%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  opacity: calc(0.05 + var(--glow, 0) * 0.08);
  transform: scale(calc(0.96 + var(--glow, 0) * 0.04));
  transition: opacity 0.4s ease, transform 0.4s ease;
  pointer-events: none;
  z-index: 0;
