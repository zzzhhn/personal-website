---
import { SITE, SOCIAL_LINKS } from "../../lib/constants";
import { UI } from "../../lib/i18n";
import TypewriterText from "../react/TypewriterText";

const githubUrl = SOCIAL_LINKS.find((l) => l.icon === "github")!.url;
const linkedinUrl = SOCIAL_LINKS.find((l) => l.icon === "linkedin")!.url;
---

<section class="hero-section">
  <!-- Ambient gradient orbs -->
  <div class="hero-ambient" aria-hidden="true">
    <div class="orb orb-1" />
    <div class="orb orb-2" />
    <div class="orb orb-3" />
  </div>

  <div class="hero-layout">
    <!-- LEFT: Photo -->
    <div class="hero-photo-side">
      <img
        src="/images/profile.jpg"
        alt={`Photo of ${SITE.name}`}
        width="800"
        height="1000"
        class="hero-photo"
        loading="eager"
      />
    </div>

    <!-- RIGHT: Content (60%) -->
    <div class="hero-content-side">
      <!-- Particle canvas — vanilla JS, no React Island -->
      <canvas id="particle-canvas" class="hero-particles" aria-hidden="true"></canvas>

      <!-- Name -->
      <h1 class="hero-name font-semibold">
        <span data-lang="en">{SITE.name}</span>
        <span data-lang="zh">钟昊楠</span>
      </h1>

      <!-- Typewriter tagline -->
      <div class="hero-tagline" data-lang="en">
        <TypewriterText
          client:load
          phrases={["Quantitative Finance × AI", "Data-Driven Solutions", "Alpha Research & Engineering"]}
        />
      </div>
      <div class="hero-tagline" data-lang="zh">
        <TypewriterText
          client:load
          phrases={["量化金融 × 人工智能", "数据驱动的解决方案", "Alpha 研究与工程"]}
        />
      </div>

      <!-- CTA Buttons -->
      <div class="hero-buttons">
        <!-- Resume (bilingual) -->
        <a data-lang="en" href="/resume-en.pdf" class="hero-btn glass glass-hover">
          <svg class="w-5 h-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span class="hero-btn-label">Resume</span>
          <span class="hero-btn-detail">Download PDF</span>
        </a>
        <a data-lang="zh" href="/resume.pdf" class="hero-btn glass glass-hover">
          <svg class="w-5 h-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span class="hero-btn-label">简历</span>
          <span class="hero-btn-detail">下载 PDF</span>
        </a>

        <!-- GitHub -->
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hero-btn glass glass-hover">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <span class="hero-btn-label">GitHub</span>
          <span class="hero-btn-detail">github.com/zzzhhn</span>
        </a>

        <!-- LinkedIn -->
        <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="hero-btn glass glass-hover">
          <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="hero-btn-label">LinkedIn</span>
          <span class="hero-btn-detail">linkedin.com/in/haonanzhong</span>
        </a>

        <!-- Email -->
        <a href={`mailto:${SITE.email}`} class="hero-btn glass glass-hover">
          <svg class="w-5 h-5 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="hero-btn-label">Email</span>
          <span class="hero-btn-detail">{SITE.email}</span>
        </a>
      </div>

      <!-- Disclaimer -->
      <p class="hero-disclaimer">
        <span data-lang="en">Resume may not reflect the most recent updates. Last updated: Apr 2026.</span>
        <span data-lang="zh">简历可能未及时更新，最近更新时间：2026 年 4 月。</span>
      </p>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* Ambient orbs */
  .hero-ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }
  .orb-1 {
    width: 500px; height: 500px;
    top: 5%; right: 10%;
    background: radial-gradient(circle, oklch(0.35 0.15 265 / 0.25), transparent 70%);
    animation: float-1 12s ease-in-out infinite;
  }
  .orb-2 {
    width: 350px; height: 350px;
    bottom: 15%; right: 25%;
    background: radial-gradient(circle, oklch(0.3 0.12 300 / 0.18), transparent 70%);
    animation: float-2 16s ease-in-out infinite;
  }
  .orb-3 {
    width: 300px; height: 300px;
    top: 40%; left: 35%;
    background: radial-gradient(circle, oklch(0.25 0.1 230 / 0.12), transparent 70%);
    animation: float-3 14s ease-in-out infinite;
  }
  @keyframes float-1 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-30px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-20px) translateX(15px); }
    66% { transform: translateY(10px) translateX(-10px); }
  }
  @keyframes float-3 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-25px); }
  }
  [data-theme="light"] .orb-1 { background: radial-gradient(circle, oklch(0.8 0.08 265 / 0.2), transparent 70%); }
  [data-theme="light"] .orb-2 { background: radial-gradient(circle, oklch(0.82 0.06 300 / 0.15), transparent 70%); }
  [data-theme="light"] .orb-3 { background: radial-gradient(circle, oklch(0.78 0.05 230 / 0.1), transparent 70%); }

  /* Layout: photo left 40%, content right 60% */
  .hero-layout {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
  }

  /* Photo side */
  .hero-photo-side {
    width: 40%;
    position: relative;
    flex-shrink: 0;
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    mask-image: linear-gradient(to right, black 0%, black 50%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 0%, black 50%, transparent 100%);
  }

  /* Content side */
  .hero-content-side {
    width: 60%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 4rem 2rem;
    position: relative;
    z-index: 2;
  }

  /* Particle canvas — fills content side, behind text */
  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-content-side > :not(.hero-particles) {
    position: relative;
    z-index: 1;
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin-bottom: 0.75rem;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    min-height: 2em;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  /* CTA buttons — stacked, full-width within content area */
  .hero-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 28rem;
  }

  .hero-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.25rem;
    text-decoration: none;
    color: var(--color-text-primary);
    border-radius: var(--radius-lg) !important;
  }
  .hero-btn-label {
    font-size: 0.9rem;
    font-weight: 600;
    flex-shrink: 0;
    min-width: 4.5rem;
  }
  .hero-btn-detail {
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    padding-left: 0.75rem;
    border-left: 1px solid var(--color-border-glass);
  }

  .hero-disclaimer {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    .hero-layout {
      flex-direction: column;
      min-height: auto;
    }
    .hero-photo-side {
      width: 100%;
      height: 50vh;
    }
    .hero-photo-side {
      width: 100%;
      height: 50vh;
    }
    .hero-photo {
      mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
    }
    .hero-content-side {
      width: 100%;
      padding: 2rem 1.5rem 4rem;
      align-items: center;
      text-align: center;
    }
    .hero-buttons {
      width: 100%;
      max-width: 100%;
    }
    .hero-disclaimer {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none !important; }
  }
</style>

<script is:inline>
(function () {
  var canvas = document.getElementById("particle-canvas");
  if (!canvas) return;
  var ctx = canvas.getContext("2d");
  if (!ctx) return;

  var particles = [];
  var mouse = { x: -1000, y: -1000 };
  var raf = 0;

  function resize() {
    var parent = canvas.parentElement;
    if (!parent) return;
    var dpr = window.devicePixelRatio || 1;
    var w = parent.clientWidth;
    var h = parent.clientHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    initParticles(w, h);
  }

  function initParticles(w, h) {
    var count = Math.max(50, Math.min(Math.floor((w * h) / 10000), 120));
    particles = [];
    for (var i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.5 + 0.5,
        o: Math.random() * 0.5 + 0.3
      });
    }
  }

  function isDark() {
    return document.documentElement.getAttribute("data-theme") !== "light";
  }

  function draw() {
    var w = canvas.clientWidth;
    var h = canvas.clientHeight;
    if (w === 0 || h === 0) { raf = requestAnimationFrame(draw); return; }
    ctx.clearRect(0, 0, w, h);

    var dark = isDark();
    var connectDist = 120;
    var i, j, p, q, dx, dy, dist, alpha;

    // Update
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0 || p.x > w) p.vx *= -1;
      if (p.y < 0 || p.y > h) p.vy *= -1;
    }

    // Lines
    ctx.lineWidth = 0.5;
    for (i = 0; i < particles.length; i++) {
      for (j = i + 1; j < particles.length; j++) {
        dx = particles[i].x - particles[j].x;
        dy = particles[i].y - particles[j].y;
        dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < connectDist) {
          alpha = (1 - dist / connectDist) * 0.35;
          ctx.strokeStyle = dark
            ? "rgba(180,195,210," + alpha + ")"
            : "rgba(60,75,95," + (alpha * 0.6) + ")";
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    // Mouse lines
    ctx.lineWidth = 0.8;
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      dx = p.x - mouse.x;
      dy = p.y - mouse.y;
      dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 150) {
        alpha = (1 - dist / 150) * 0.5;
        ctx.strokeStyle = dark
          ? "rgba(130,150,255," + alpha + ")"
          : "rgba(50,70,190," + (alpha * 0.5) + ")";
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(mouse.x, mouse.y);
        ctx.stroke();
      }
    }

    // Dots
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, 6.283);
      ctx.fillStyle = dark
        ? "rgba(200,210,225," + (p.o * 0.85) + ")"
        : "rgba(50,65,85," + (p.o * 0.55) + ")";
      ctx.fill();
    }

    raf = requestAnimationFrame(draw);
  }

  canvas.addEventListener("mousemove", function (e) {
    var rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });
  canvas.addEventListener("mouseleave", function () {
    mouse.x = -1000;
    mouse.y = -1000;
  });

  // Enable pointer events only for mouse tracking
  canvas.style.pointerEvents = "auto";

  window.addEventListener("resize", resize);
  resize();
  raf = requestAnimationFrame(draw);
})();
</script>
