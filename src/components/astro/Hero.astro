---
import { SITE, SOCIAL_LINKS } from "../../lib/constants";
import { UI } from "../../lib/i18n";
import TypewriterText from "../react/TypewriterText";

const githubUrl = SOCIAL_LINKS.find((l) => l.icon === "github")!.url;
const linkedinUrl = SOCIAL_LINKS.find((l) => l.icon === "linkedin")!.url;
---

<section class="hero-section">
  <!-- Ambient gradient orbs -->
  <div class="hero-ambient" aria-hidden="true">
    <div class="orb orb-1" />
    <div class="orb orb-2" />
    <div class="orb orb-3" />
  </div>

  <div class="hero-layout">
    <!-- LEFT: Photo -->
    <div class="hero-photo-side">
      <img
        src="/images/profile.jpg"
        alt={`Photo of ${SITE.name}`}
        width="800"
        height="1000"
        class="hero-photo hero-photo--light"
        loading="eager"
      />
      <img
        src="/images/profile-dark.png"
        alt={`Photo of ${SITE.name}`}
        width="800"
        height="1000"
        class="hero-photo hero-photo--dark"
        loading="eager"
      />
    </div>

    <!-- RIGHT: Content (60%) -->
    <div class="hero-content-side">
      <!-- Particle canvas — vanilla JS, no React Island -->
      <canvas id="particle-canvas" class="hero-particles" aria-hidden="true"></canvas>

      <!-- Name — kinetic typography: each char responds to hover -->
      <h1 class="hero-name">
        <span class="hero-name-en" data-lang="en">
          <span class="hero-name-variant hero-name-variant--active" data-name="full">
            {SITE.name.split('').map((ch, i) => (
              <span class={`hc${ch === ' ' ? ' hc-space' : ''}`} style={`--ci:${i}`}>{ch === ' ' ? '\u00A0' : ch}</span>
            ))}
          </span>
          <span class="hero-name-variant" data-name="nick">
            {'Bobby'.split('').map((ch, i) => (
              <span class="hc" style={`--ci:${i}`}>{ch}</span>
            ))}
          </span>
        </span>
        <span class="hero-name-zh" data-lang="zh">
          {'钟昊楠'.split('').map((ch, i) => (
            <span class="hc" style={`--ci:${i}`}>{ch}</span>
          ))}
        </span>
      </h1>

      <!-- Typewriter tagline -->
      <div class="hero-tagline" data-lang="en">
        <TypewriterText
          client:load
          phrases={["Quantitative Finance × AI", "Data-Driven Solutions", "Alpha Research & Engineering"]}
        />
      </div>
      <div class="hero-tagline" data-lang="zh">
        <TypewriterText
          client:load
          phrases={["量化金融 × 人工智能", "数据驱动的解决方案", "Alpha 研究与工程"]}
        />
      </div>

      <!-- Bio summary -->
      <p class="hero-bio" data-lang="en">
        Undergraduate at CUHK-Shenzhen, building data-driven solutions at the intersection of finance and technology.
      </p>
      <p class="hero-bio" data-lang="zh">
        香港中文大学（深圳）本科生，专注于金融与科技交汇处的数据驱动解决方案。
      </p>

      <!-- Keyword chips -->
      <div class="hero-chips">
        <span class="hero-chip" data-lang="en">PM × Engineer</span>
        <span class="hero-chip" data-lang="zh">产品经理 × 工程师</span>
        <span class="hero-chip" data-lang="en">Alpha Research</span>
        <span class="hero-chip" data-lang="zh">Alpha 策略研究</span>
        <span class="hero-chip" data-lang="en">Full-Stack</span>
        <span class="hero-chip" data-lang="zh">全栈开发</span>
        <span class="hero-chip" data-lang="en">AI Driven</span>
        <span class="hero-chip" data-lang="zh">AI 驱动</span>
      </div>

      <!-- Social links -->
      <div class="hero-actions">
        <div class="hero-icon-links">
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hero-icon-btn" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="hero-icon-btn" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={`mailto:${SITE.email}`} class="hero-icon-btn" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* Ambient orbs */
  .hero-ambient {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }
  .orb-1 {
    width: 500px; height: 500px;
    top: 5%; right: 10%;
    background: radial-gradient(circle, oklch(0.35 0.15 265 / 0.25), transparent 70%);
    animation: float-1 12s ease-in-out infinite;
  }
  .orb-2 {
    width: 350px; height: 350px;
    bottom: 15%; right: 25%;
    background: radial-gradient(circle, oklch(0.3 0.12 300 / 0.18), transparent 70%);
    animation: float-2 16s ease-in-out infinite;
  }
  .orb-3 {
    width: 300px; height: 300px;
    top: 40%; left: 35%;
    background: radial-gradient(circle, oklch(0.25 0.1 230 / 0.12), transparent 70%);
    animation: float-3 14s ease-in-out infinite;
  }
  @keyframes float-1 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-30px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translateY(0) translateX(0); }
    33% { transform: translateY(-20px) translateX(15px); }
    66% { transform: translateY(10px) translateX(-10px); }
  }
  @keyframes float-3 {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-25px); }
  }
  [data-theme="light"] .orb-1 { background: radial-gradient(circle, oklch(0.8 0.08 265 / 0.2), transparent 70%); }
  [data-theme="light"] .orb-2 { background: radial-gradient(circle, oklch(0.82 0.06 300 / 0.15), transparent 70%); }
  [data-theme="light"] .orb-3 { background: radial-gradient(circle, oklch(0.78 0.05 230 / 0.1), transparent 70%); }

  /* Layout: photo left 40%, content right 60% */
  .hero-layout {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: stretch;
  }

  /* Photo side */
  .hero-photo-side {
    width: 40%;
    position: relative;
    flex-shrink: 0;
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    mask-image:
      linear-gradient(to right, black 0%, black 65%, transparent 95%),
      linear-gradient(to bottom, black 0%, black 82%, transparent 100%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to right, black 0%, black 65%, transparent 95%),
      linear-gradient(to bottom, black 0%, black 82%, transparent 100%);
    -webkit-mask-composite: source-in;
  }
  /* Light/dark photo toggle */
  .hero-photo--dark { display: none; }
  :global([data-theme="dark"]) .hero-photo--light { display: none; }
  :global([data-theme="dark"]) .hero-photo--dark { display: block; }

  /* Content side */
  .hero-content-side {
    width: 60%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 4rem 2rem;
    position: relative;
    z-index: 2;
  }

  /* Particle canvas — fills content side, behind text */
  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero-content-side > :not(.hero-particles) {
    position: relative;
    z-index: 1;
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    line-height: 1.05;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }

  /* Each character is an inline-block so transform works */
  .hc {
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: default;
    transform-origin: center bottom;
  }
  .hc-space {
    /* Spaces don't scale but need inline-block for layout */
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hc {
      transition: none !important;
    }
  }
  .hero-name-en {
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: -0.03em;
    cursor: pointer;
    position: relative;
  }
  /* Name toggle: staggered per-character slide */
  .hero-name-variant {
    display: inline-flex;
  }
  .hero-name-variant:not(.hero-name-variant--active) {
    position: absolute;
    left: 0;
    top: 0;
    pointer-events: none;
  }
  .hero-name-variant:not(.hero-name-variant--active) .hc {
    opacity: 0;
    transform: translateX(-18px);
  }
  .hero-name-variant--exiting .hc {
    opacity: 0 !important;
    transform: translateX(-18px) !important;
  }
  .hero-name-variant--entering .hc {
    opacity: 1 !important;
    transform: translateX(0) !important;
  }
  .hc {
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275),
                opacity 0.3s ease;
  }
  .hero-name-zh {
    font-family: "Noto Serif SC", "Source Han Serif SC", "SimSun", "STSong", serif;
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-text-secondary);
    margin-bottom: 2.5rem;
    min-height: 2em;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  /* Bio summary */
  .hero-bio {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-top: 0.75rem;
    max-width: 28rem;
  }

  /* Keyword chips */
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .hero-chip {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    background: var(--color-surface-glass);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .hero-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
  }

  /* CTA — primary pill + icon links row */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-primary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: 100px;
    transition: background 0.25s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  }
  .hero-primary-cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--color-accent-glow);
  }

  .hero-icon-links {
    display: flex;
    gap: 0.75rem;
  }
  .hero-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    border: 1.5px solid var(--color-border-glass);
    color: var(--color-text-secondary);
    text-decoration: none;
    background: var(--color-surface-glass);
    backdrop-filter: blur(12px) saturate(130%);
    -webkit-backdrop-filter: blur(12px) saturate(130%);
    box-shadow:
      0 1px 6px var(--color-shadow-depth),
      inset 0 1px 0 var(--color-inset-highlight);
    transition: color 0.25s ease, border-color 0.25s ease,
                transform 0.25s ease, box-shadow 0.25s ease;
  }
  .hero-icon-btn svg {
    width: 1.2rem;
    height: 1.2rem;
  }
  .hero-icon-btn:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow:
      0 4px 12px var(--color-shadow-depth-hover),
      0 0 8px var(--color-accent-glow),
      inset 0 1px 0 var(--color-inset-highlight-hover);
  }


  /* Mobile: stack vertically */
  @media (max-width: 768px) {
    .hero-layout {
      flex-direction: column;
      min-height: auto;
    }
    .hero-photo-side {
      width: 100%;
      height: 50vh;
    }
    .hero-photo-side {
      width: 100%;
      height: 50vh;
    }
    .hero-photo {
      mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 0%, black 50%, transparent 100%);
    }
    .hero-content-side {
      width: 100%;
      padding: 2rem 1.5rem 4rem;
      align-items: center;
      text-align: center;
    }
    .hero-bio {
      text-align: center;
      max-width: 100%;
    }
    .hero-chips {
      justify-content: center;
    }
    .hero-actions {
      justify-content: center;
    }
    .hero-disclaimer {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none !important; }
  }
</style>

<script is:inline>
// Kinetic typography — smooth Gaussian wave via mousemove
(function () {
  var name = document.querySelector(".hero-name");
  if (!name) return;
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

  var pending = false;
  var mouseX = -9999;
  var isInside = false;

  function update() {
    pending = false;
    var spans = name.querySelectorAll(".hc:not(.hc-space)");
    for (var i = 0; i < spans.length; i++) {
      var el = spans[i];
      if (el.offsetParent === null) { el.style.transform = ""; continue; }
      if (!isInside) { el.style.transform = ""; continue; }
      var rect = el.getBoundingClientRect();
      var cx = rect.left + rect.width / 2;
      var dist = Math.abs(mouseX - cx);
      // Gaussian falloff: peak 1.28, sigma ~60px
      var scale = 1 + 0.28 * Math.exp(-(dist * dist) / 7200);
      el.style.transform = scale > 1.01 ? "scale(" + scale.toFixed(3) + ")" : "";
    }
  }

  name.addEventListener("mousemove", function (e) {
    mouseX = e.clientX;
    isInside = true;
    if (!pending) { pending = true; requestAnimationFrame(update); }
  });
  name.addEventListener("mouseleave", function () {
    isInside = false;
    if (!pending) { pending = true; requestAnimationFrame(update); }
  });

  /* ── Name toggle: click to swap "Haonan Zhong" ↔ "Bobby" ── */
  var enWrap = document.querySelector(".hero-name-en");
  if (enWrap) {
    var variants = enWrap.querySelectorAll(".hero-name-variant");
    var animating = false;

    enWrap.addEventListener("click", function () {
      if (animating || variants.length < 2) return;
      animating = true;

      var active = enWrap.querySelector(".hero-name-variant--active");
      var next = active === variants[0] ? variants[1] : variants[0];
      var STAGGER = 35; /* ms per character */

      /* Phase 1: exit active — stagger from left */
      active.classList.add("hero-name-variant--exiting");
      var exitChars = active.querySelectorAll(".hc:not(.hc-space)");
      for (var i = 0; i < exitChars.length; i++) {
        exitChars[i].style.transitionDelay = (i * STAGGER) + "ms";
      }

      var exitDuration = exitChars.length * STAGGER + 300;

      setTimeout(function () {
        /* Swap active class */
        active.classList.remove("hero-name-variant--active", "hero-name-variant--exiting");
        /* Reset exit delays */
        for (var i = 0; i < exitChars.length; i++) {
          exitChars[i].style.transitionDelay = "";
        }

        /* Phase 2: enter next — stagger from left */
        next.classList.add("hero-name-variant--active", "hero-name-variant--entering");
        var enterChars = next.querySelectorAll(".hc:not(.hc-space)");
        for (var j = 0; j < enterChars.length; j++) {
          enterChars[j].style.transitionDelay = (j * STAGGER) + "ms";
        }

        var enterDuration = enterChars.length * STAGGER + 350;
        setTimeout(function () {
          next.classList.remove("hero-name-variant--entering");
          for (var j = 0; j < enterChars.length; j++) {
            enterChars[j].style.transitionDelay = "";
          }
          animating = false;
        }, enterDuration);
      }, exitDuration);
    });
  }
})();
</script>

<script is:inline>
(function () {
  var canvas = document.getElementById("particle-canvas");
  if (!canvas) return;
  var ctx = canvas.getContext("2d");
  if (!ctx) return;

  var particles = [];
  var mouse = { x: -1000, y: -1000 };
  var raf = 0;

  // Antigravity state (light mode)
  var lastMousePos = { x: 0, y: 0 };
  var lastMouseMoveTime = 0;
  var virtualMouse = { x: -1000, y: -1000 };
  var autoAnimateDelay = 3000; // ms before auto-animate kicks in

  // Bokeh color palette for light mode (warm gold, matches scroll bar)
  var bokehColors = [
    [190, 155, 60],
    [175, 140, 50],
    [200, 165, 75],
  ];

  function resize() {
    var parent = canvas.parentElement;
    if (!parent) return;
    var dpr = window.devicePixelRatio || 1;
    var w = parent.clientWidth;
    var h = parent.clientHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    initParticles(w, h);
  }

  function initParticles(w, h) {
    // High density: ~300 on a 1440x900 screen
    var count = Math.max(250, Math.min(Math.floor((w * h) / 3000), 500));
    particles = [];
    for (var i = 0; i < count; i++) {
      var col = bokehColors[Math.floor(Math.random() * bokehColors.length)];
      var px = Math.random() * w;
      var py = Math.random() * h;
      particles.push({
        x: px,
        y: py,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.5 + 0.5,         // star radius (dark)
        br: Math.random() * 12 + 4,            // bokeh radius (light)
        o: Math.random() * 0.5 + 0.3,
        col: col,
        phase: Math.random() * 6.283,
        speed: 0.01 + Math.random() * 0.005,   // per-particle time speed
        t: Math.random() * 100,                 // per-particle time accumulator
        // Antigravity fields (light mode)
        hx: px, hy: py,                         // home position
        ax: px, ay: py,                         // animated position
        rOff: (Math.random() - 0.5) * 8         // ring radius jitter
      });
    }
  }

  function isDark() {
    return document.documentElement.getAttribute("data-theme") !== "light";
  }

  function drawDark(w, h, t) {
    var connectDist = 120;
    var i, j, p, dx, dy, dist, alpha;

    // Lines between stars
    ctx.lineWidth = 0.5;
    for (i = 0; i < particles.length; i++) {
      for (j = i + 1; j < particles.length; j++) {
        dx = particles[i].x - particles[j].x;
        dy = particles[i].y - particles[j].y;
        dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < connectDist) {
          alpha = (1 - dist / connectDist) * 0.35;
          ctx.strokeStyle = "rgba(180,195,210," + alpha + ")";
          ctx.beginPath();
          ctx.moveTo(particles[i].x, particles[i].y);
          ctx.lineTo(particles[j].x, particles[j].y);
          ctx.stroke();
        }
      }
    }

    // Mouse constellation lines
    ctx.lineWidth = 0.8;
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      dx = p.x - mouse.x;
      dy = p.y - mouse.y;
      dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 150) {
        alpha = (1 - dist / 150) * 0.5;
        ctx.strokeStyle = "rgba(130,150,255," + alpha + ")";
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(mouse.x, mouse.y);
        ctx.stroke();
      }
    }

    // Star dots
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, 6.283);
      ctx.fillStyle = "rgba(200,210,225," + (p.o * 0.85) + ")";
      ctx.fill();
    }
  }

  function drawLight(w, h, t) {
    // Match original: large magnet zone, wide ring, thick visible band
    var magnetRadius = 350, ringRadius = 150, lerpSpeed = 0.12;
    var visRadius = 130; // thick donut — particles visible ±130px from ring center
    var i, p, dx, dy, dist, tx, ty, angle, wave, rr, c;

    // --- Virtual mouse: responsive when active, smooth trail when idle ---
    var now = Date.now();
    var destX, destY;
    var mouseActive = mouse.x > 0;
    var idle = now - lastMouseMoveTime > autoAnimateDelay;

    if (mouseActive) {
      destX = mouse.x;
      destY = mouse.y;
    } else if (idle) {
      var at = t * 0.001;
      destX = w / 2 + Math.sin(at * 0.5) * (w * 0.3);
      destY = h / 2 + Math.cos(at * 0.7) * (h * 0.25);
    } else {
      destX = virtualMouse.x;
      destY = virtualMouse.y;
    }

    // Fast lerp when mouse active (0.25), slow trail for auto-animate (0.04)
    var smoothF = mouseActive ? 0.25 : 0.04;
    virtualMouse.x += (destX - virtualMouse.x) * smoothF;
    virtualMouse.y += (destY - virtualMouse.y) * smoothF;

    var vx = virtualMouse.x, vy = virtualMouse.y;

    // --- Physics: pull particles within magnetRadius into ring ---
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      p.t += p.speed;

      dx = p.hx - vx;
      dy = p.hy - vy;
      dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < magnetRadius) {
        angle = Math.atan2(dy, dx);
        wave = Math.sin(p.t * 8 + angle) * 6;
        // Spread particles across the ring with per-particle offset
        rr = ringRadius + wave + p.rOff * 3;
        tx = vx + rr * Math.cos(angle);
        ty = vy + rr * Math.sin(angle);
      } else {
        tx = p.hx + Math.sin(p.t * 0.5 + p.phase) * 2;
        ty = p.hy + Math.cos(p.t * 0.4 + p.phase * 1.3) * 2;
      }

      p.ax += (tx - p.ax) * lerpSpeed;
      p.ay += (ty - p.ay) * lerpSpeed;
    }

    // --- Draw: visible within thick donut band around ring ---
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      c = p.col;

      dx = p.ax - vx;
      dy = p.ay - vy;
      dist = Math.sqrt(dx * dx + dy * dy);
      var ringDist = Math.abs(dist - ringRadius);

      var scaleFactor = Math.max(0, Math.min(1, 1 - ringDist / visRadius));
      if (scaleFactor < 0.01) continue;

      var pulse = 0.85 + Math.sin(p.t * 6) * 0.15;
      var sz = scaleFactor * pulse * 9;

      angle = Math.atan2(vy - p.ay, vx - p.ax);

      ctx.save();
      ctx.translate(p.ax, p.ay);
      ctx.rotate(angle);

      var capW = sz * 2.5, capH = sz;
      var capR = capH / 2;
      ctx.beginPath();
      ctx.moveTo(-capW / 2 + capR, -capH / 2);
      ctx.lineTo(capW / 2 - capR, -capH / 2);
      ctx.arc(capW / 2 - capR, 0, capR, -Math.PI / 2, Math.PI / 2);
      ctx.lineTo(-capW / 2 + capR, capH / 2);
      ctx.arc(-capW / 2 + capR, 0, capR, Math.PI / 2, -Math.PI / 2);
      ctx.closePath();

      var alpha = scaleFactor * 0.8;
      ctx.fillStyle = "rgba(" + c[0] + "," + c[1] + "," + c[2] + "," + alpha + ")";
      ctx.fill();

      ctx.restore();
    }
  }

  function draw(t) {
    var w = canvas.clientWidth;
    var h = canvas.clientHeight;
    if (w === 0 || h === 0) { raf = requestAnimationFrame(draw); return; }
    ctx.clearRect(0, 0, w, h);

    var dark = isDark();
    var i, p;

    // Update positions (shared)
    for (i = 0; i < particles.length; i++) {
      p = particles[i];
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < 0 || p.x > w) p.vx *= -1;
      if (p.y < 0 || p.y > h) p.vy *= -1;
    }

    if (dark) {
      drawDark(w, h, t);
    } else {
      drawLight(w, h, t);
    }

    raf = requestAnimationFrame(draw);
  }

  canvas.addEventListener("mousemove", function (e) {
    var rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
    // Track idle for auto-animate
    var mdx = mouse.x - lastMousePos.x, mdy = mouse.y - lastMousePos.y;
    if (Math.sqrt(mdx * mdx + mdy * mdy) > 1) {
      lastMouseMoveTime = Date.now();
      lastMousePos.x = mouse.x;
      lastMousePos.y = mouse.y;
    }
  });
  canvas.addEventListener("mouseleave", function () {
    mouse.x = -1000;
    mouse.y = -1000;
  });

  canvas.style.pointerEvents = "auto";
  window.addEventListener("resize", resize);
  resize();
  raf = requestAnimationFrame(draw);
})();
</script>
