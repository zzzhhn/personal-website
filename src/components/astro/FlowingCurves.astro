---
/**
 * Three flowing Bézier curves that progressively "draw" as the user scrolls
 * down past the Hero section, and retract when scrolling back up.
 *
 * Placed as position:absolute inside a relative wrapper that contains all
 * post-Hero sections. Uses stroke-dashoffset driven by scroll progress.
 */
---

<div id="flowing-curves" aria-hidden="true">
  <svg id="fc-svg" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"></svg>
</div>

<style is:global>
  #flowing-curves {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  #fc-svg {
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline>
(function () {
  var svg = document.getElementById("fc-svg");
  if (!svg) return;

  /* ── per-curve config ────────────────────────────────────── */
  // colorVar: CSS custom property name (different per curve for differentiation)
  // dark/light opacity tuned separately so all 3 curves are clearly visible
  var CURVES = [
    { colorVar: "--color-accent",      darkOp: 0.25, lightOp: 0.18, width: 3.5 },
    { colorVar: "--color-accent-teal", darkOp: 0.20, lightOp: 0.16, width: 2.8 },
    { colorVar: "--color-accent-warm", darkOp: 0.18, lightOp: 0.14, width: 2.2 },
  ];

  // Number of anchor points per curve (controls how many S-bends)
  var ANCHORS = 7;

  var paths = [];
  var lengths = [];
  var containerH = 0;

  /* ── helpers ──────────────────────────────────────────────── */
  function cssVar(name) {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  function isLight() {
    return document.documentElement.getAttribute("data-theme") === "light";
  }

  /** Seeded-ish random: generate a random x-position array for one curve.
   *  band = [lo, hi] constrains where this curve wanders (0-1 range).
   *  Each anchor is randomised within the band, ensuring smooth variety. */
  function randomAnchors(band, n) {
    var lo = band[0], hi = band[1];
    var xs = [];
    for (var i = 0; i < n; i++) {
      // Alternate between left-leaning and right-leaning within band
      var center = i % 2 === 0 ? lo + (hi - lo) * 0.25 : lo + (hi - lo) * 0.75;
      var jitter = (hi - lo) * 0.25;
      var x = center + (Math.random() * 2 - 1) * jitter;
      // Clamp to band
      xs.push(Math.max(lo, Math.min(hi, x)));
    }
    return xs;
  }

  // Each curve wanders within a horizontal band to avoid overlap
  var BANDS = [
    [0.05, 0.40],  // curve 1: left region
    [0.30, 0.70],  // curve 2: center region (overlaps slightly for organic feel)
    [0.60, 0.95],  // curve 3: right region
  ];

  /** Build a smooth cubic-Bézier "d" attribute from x-position anchors */
  function buildPath(xs, w, h) {
    var n = xs.length;
    var segH = h / (n - 1);
    var d = "M " + (xs[0] * w) + " 0";
    for (var i = 1; i < n; i++) {
      var x0 = xs[i - 1] * w;
      var y0 = (i - 1) * segH;
      var x1 = xs[i] * w;
      var y1 = i * segH;
      // Control points at 35%/65% for a fluid S-curve
      var cy0 = y0 + segH * 0.35;
      var cy1 = y0 + segH * 0.65;
      d += " C " + x0 + " " + cy0 + ", " + x1 + " " + cy1 + ", " + x1 + " " + y1;
    }
    return d;
  }

  /* ── setup — called on load & resize ─────────────────────── */
  function setup() {
    var container = document.getElementById("flowing-curves");
    if (!container) return;
    containerH = container.parentElement ? container.parentElement.scrollHeight : 0;
    if (containerH <= 0) return;

    var w = container.offsetWidth;
    svg.setAttribute("viewBox", "0 0 " + w + " " + containerH);
    svg.innerHTML = "";

    var light = isLight();
    paths = [];
    lengths = [];

    CURVES.forEach(function (cfg, i) {
      // Random path each time setup is called (page load / resize)
      var xs = randomAnchors(BANDS[i], ANCHORS);
      var d = buildPath(xs, w, containerH);
      var color = cssVar(cfg.colorVar) || "#64ffda";
      var opacity = light ? cfg.lightOp : cfg.darkOp;

      var p = document.createElementNS("http://www.w3.org/2000/svg", "path");
      p.setAttribute("d", d);
      p.setAttribute("stroke", color);
      p.setAttribute("stroke-width", String(cfg.width));
      p.setAttribute("fill", "none");
      p.setAttribute("opacity", String(opacity));
      p.setAttribute("stroke-linecap", "round");
      p.setAttribute("stroke-linejoin", "round");
      svg.appendChild(p);

      var len = p.getTotalLength();
      p.style.strokeDasharray = String(len);
      p.style.strokeDashoffset = String(len);
      paths.push(p);
      lengths.push(len);
    });

    tick();
  }

  /* ── scroll-driven progressive draw ─────────────────────── */
  function tick() {
    var scrollY = window.scrollY;
    var viewH = window.innerHeight;

    var container = document.getElementById("flowing-curves");
    if (!container || !container.parentElement) return;
    var wrapTop = container.parentElement.getBoundingClientRect().top + scrollY;
    var scrollStart = wrapTop - viewH * 0.8;
    var scrollEnd = wrapTop + containerH - viewH;
    var range = scrollEnd - scrollStart;
    if (range <= 0) return;

    var progress = Math.max(0, Math.min(1, (scrollY - scrollStart) / range));

    for (var i = 0; i < paths.length; i++) {
      var stagger = i * 0.04;
      var p = Math.max(0, Math.min(1, (progress - stagger) / (1 - stagger)));
      paths[i].style.strokeDashoffset = String(lengths[i] * (1 - p));
    }
  }

  /* ── event wiring ───────────────────────────────────────── */
  var ticking = false;
  window.addEventListener("scroll", function () {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(function () { tick(); ticking = false; });
    }
  }, { passive: true });

  var resizeTimer;
  window.addEventListener("resize", function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(setup, 200);
  }, { passive: true });

  // Theme toggle → update colors AND opacities
  new MutationObserver(function () {
    var light = isLight();
    CURVES.forEach(function (cfg, i) {
      if (!paths[i]) return;
      paths[i].setAttribute("stroke", cssVar(cfg.colorVar) || "#64ffda");
      paths[i].setAttribute("opacity", String(light ? cfg.lightOp : cfg.darkOp));
    });
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  if (document.readyState === "complete") {
    setup();
  } else {
    window.addEventListener("load", setup);
  }
})();
</script>
