---
/**
 * Three flowing Bézier curves that progressively "draw" as the user scrolls
 * down past the Hero section, and retract when scrolling back up.
 *
 * Placed as position:absolute inside a relative wrapper that contains all
 * post-Hero sections. Uses stroke-dashoffset driven by scroll progress.
 */
---

<div id="flowing-curves" aria-hidden="true">
  <svg id="fc-svg" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"></svg>
</div>

<style is:global>
  #flowing-curves {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }
  #fc-svg {
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline>
(function () {
  var svg = document.getElementById("fc-svg");
  if (!svg) return;

  /* ── per-curve config ────────────────────────────────────── */
  // Fixed anchor paths (x-positions 0-1 at evenly-spaced vertical points)
  // Dark: brighter, more saturated strokes on dark bg
  // Light: deeper, richer strokes on light bg — NOT just lower opacity
  var CURVES = [
    {
      xs: [0.12, 0.62, 0.18, 0.68, 0.15, 0.58, 0.22],
      width: 3.5,
      dark:  { color: "oklch(0.75 0.18 255 / 0.35)" },
      light: { color: "oklch(0.45 0.22 255 / 0.22)" },
    },
    {
      xs: [0.52, 0.18, 0.58, 0.12, 0.55, 0.22, 0.48],
      width: 2.8,
      dark:  { color: "oklch(0.78 0.14 165 / 0.28)" },
      light: { color: "oklch(0.42 0.18 165 / 0.18)" },
    },
    {
      xs: [0.85, 0.38, 0.78, 0.42, 0.82, 0.35, 0.80],
      width: 2.2,
      dark:  { color: "oklch(0.80 0.15 55 / 0.25)" },
      light: { color: "oklch(0.50 0.20 55 / 0.16)" },
    },
  ];

  var paths = [];
  var lengths = [];
  var containerH = 0;

  /* ── helpers ──────────────────────────────────────────────── */
  function isLight() {
    return document.documentElement.getAttribute("data-theme") === "light";
  }

  /** Build a smooth cubic-Bézier "d" attribute from x-position anchors */
  function buildPath(xs, w, h) {
    var n = xs.length;
    var segH = h / (n - 1);
    var d = "M " + (xs[0] * w) + " 0";
    for (var i = 1; i < n; i++) {
      var x0 = xs[i - 1] * w;
      var y0 = (i - 1) * segH;
      var x1 = xs[i] * w;
      var y1 = i * segH;
      var cy0 = y0 + segH * 0.35;
      var cy1 = y0 + segH * 0.65;
      d += " C " + x0 + " " + cy0 + ", " + x1 + " " + cy1 + ", " + x1 + " " + y1;
    }
    return d;
  }

  function applyColors() {
    var light = isLight();
    CURVES.forEach(function (cfg, i) {
      if (!paths[i]) return;
      var scheme = light ? cfg.light : cfg.dark;
      paths[i].setAttribute("stroke", scheme.color);
      paths[i].setAttribute("opacity", "1");
    });
  }

  /* ── setup ───────────────────────────────────────────────── */
  function setup() {
    var container = document.getElementById("flowing-curves");
    if (!container) return;
    containerH = container.parentElement ? container.parentElement.scrollHeight : 0;
    if (containerH <= 0) return;

    var w = container.offsetWidth;
    svg.setAttribute("viewBox", "0 0 " + w + " " + containerH);
    svg.innerHTML = "";

    paths = [];
    lengths = [];

    CURVES.forEach(function (cfg) {
      var d = buildPath(cfg.xs, w, containerH);
      var p = document.createElementNS("http://www.w3.org/2000/svg", "path");
      p.setAttribute("d", d);
      p.setAttribute("stroke-width", String(cfg.width));
      p.setAttribute("fill", "none");
      p.setAttribute("stroke-linecap", "round");
      p.setAttribute("stroke-linejoin", "round");
      svg.appendChild(p);

      var len = p.getTotalLength();
      p.style.strokeDasharray = String(len);
      p.style.strokeDashoffset = String(len);
      paths.push(p);
      lengths.push(len);
    });

    applyColors();
    tick();
  }

  /* ── scroll-driven progressive draw ─────────────────────── */
  function tick() {
    var scrollY = window.scrollY;
    var viewH = window.innerHeight;

    var container = document.getElementById("flowing-curves");
    if (!container || !container.parentElement) return;
    var wrapTop = container.parentElement.getBoundingClientRect().top + scrollY;
    var scrollStart = wrapTop - viewH * 0.8;
    var scrollEnd = wrapTop + containerH - viewH;
    var range = scrollEnd - scrollStart;
    if (range <= 0) return;

    var progress = Math.max(0, Math.min(1, (scrollY - scrollStart) / range));

    for (var i = 0; i < paths.length; i++) {
      var stagger = i * 0.04;
      var p = Math.max(0, Math.min(1, (progress - stagger) / (1 - stagger)));
      paths[i].style.strokeDashoffset = String(lengths[i] * (1 - p));
    }
  }

  /* ── event wiring ───────────────────────────────────────── */
  var ticking = false;
  window.addEventListener("scroll", function () {
    if (!ticking) {
      ticking = true;
      requestAnimationFrame(function () { tick(); ticking = false; });
    }
  }, { passive: true });

  var resizeTimer;
  window.addEventListener("resize", function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(setup, 200);
  }, { passive: true });

  // Theme toggle → swap to the other color scheme
  new MutationObserver(function () {
    applyColors();
  }).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });

  if (document.readyState === "complete") {
    setup();
  } else {
    window.addEventListener("load", setup);
  }
})();
</script>
