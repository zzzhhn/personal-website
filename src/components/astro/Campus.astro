---
import { UI } from "../../lib/i18n";
import SectionHeading from "./SectionHeading.astro";
---

<section id="campus" class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
  <div class="mx-auto" style="max-width: var(--max-width-content);">
    <SectionHeading variant="numbered" number="05" titleEn={UI.sections.campus.en} titleZh={UI.sections.campus.zh} />

    <div class="space-y-6 mx-auto campus-tilt-stack" style="max-width: 48rem;">
      {UI.campus.map((entry) => (
        <div class="card-outline p-8 tilt-card">
          <div class="tilt-card-inner">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6 tilt-layer-front">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--color-text-primary);">
                <span data-lang="en" style="font-family: 'Times New Roman', Times, serif;">{entry.role.en}</span>
                <span data-lang="zh" style="font-family: 'Kaiti SC', 'STKaiti', 'KaiTi', serif;">{entry.role.zh}</span>
              </h3>
              <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
                <span data-lang="en">{entry.org.en}</span>
                <span data-lang="zh">{entry.org.zh}</span>
              </p>
            </div>
            <span class="glass-subtle px-3 py-1 text-xs font-medium" style="color: var(--color-text-secondary);">
              <span data-lang="en">{entry.period.en}</span>
              <span data-lang="zh">{entry.period.zh}</span>
            </span>
          </div>

          <!-- EN items -->
          <ul data-lang="en" class="space-y-3">
            {entry.items.en.map((item) => (
              <li class="text-sm flex items-start gap-2.5" style="color: var(--color-text-secondary);">
                <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                <span><strong style="color: var(--color-text-primary);">{item.label}:</strong> {item.text}</span>
              </li>
            ))}
          </ul>
          <!-- ZH items -->
          <ul data-lang="zh" class="space-y-3">
            {entry.items.zh.map((item) => (
              <li class="text-sm flex items-start gap-2.5" style="color: var(--color-text-secondary);">
                <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                <span><strong style="color: var(--color-text-primary);">{item.label}：</strong>{item.text}</span>
              </li>
            ))}
          </ul>
          </div>
          <div class="tilt-card-glare" aria-hidden="true"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .campus-tilt-stack {
    perspective: 1400px;
    perspective-origin: 50% 50%;
  }
  .tilt-card {
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(0deg) rotateY(0deg);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
    will-change: transform;
  }
  .tilt-card.tilt-active {
    transition: transform 0.08s linear, box-shadow 0.4s ease;
  }
  .tilt-card-inner {
    transform-style: preserve-3d;
  }
  .tilt-card-inner > * {
    transition: transform 0.18s ease-out;
  }
  .tilt-card.tilt-active .tilt-layer-front {
    transform: translateZ(28px);
  }
  .tilt-card-glare {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    --glare-rgb: 255, 255, 255;
    background: radial-gradient(
      circle at var(--glare-x, 50%) var(--glare-y, 50%),
      rgba(var(--glare-rgb), var(--glare-strength, 0)) 0%,
      transparent 50%
    );
    mix-blend-mode: overlay;
    transition: opacity 0.3s ease;
    opacity: 0;
  }
  /* Light mode: warm gold matching particle bokeh, normal blend (overlay washes out on white) */
  :global([data-theme="light"]) .tilt-card-glare {
    --glare-rgb: 200, 160, 70;
    mix-blend-mode: normal;
  }
  .tilt-card.tilt-active .tilt-card-glare {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tilt-card,
    .tilt-card.tilt-active,
    .tilt-card-inner > * {
      transition: none !important;
      transform: none !important;
    }
    .tilt-card-glare { display: none; }
  }
</style>

<script is:inline>
/* ── Campus card 3D parallax tilt ── */
(function () {
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
  var cards = document.querySelectorAll(".tilt-card");
  if (!cards.length) return;

  var TILT_MAX = 5;       // degrees
  var lerpFactor = 0.18;

  cards.forEach(function (card) {
    var targetX = 0, targetY = 0;
    var currentX = 0, currentY = 0;
    var raf = 0;
    var hovering = false;

    function update() {
      raf = 0;
      currentX += (targetX - currentX) * lerpFactor;
      currentY += (targetY - currentY) * lerpFactor;

      var rotY = currentX * TILT_MAX;
      var rotX = -currentY * TILT_MAX;
      card.style.transform = "rotateY(" + rotY.toFixed(2) + "deg) rotateX(" + rotX.toFixed(2) + "deg)";

      // Glare follows cursor (px to %)
      var isLight = document.documentElement.getAttribute("data-theme") === "light";
      var strength = isLight ? "0.28" : "0.10";
      card.style.setProperty("--glare-x", ((currentX + 1) * 50).toFixed(1) + "%");
      card.style.setProperty("--glare-y", ((currentY + 1) * 50).toFixed(1) + "%");
      card.style.setProperty("--glare-strength", hovering ? strength : "0");

      if (Math.abs(targetX - currentX) > 0.002 || Math.abs(targetY - currentY) > 0.002) {
        raf = requestAnimationFrame(update);
      }
    }

    card.addEventListener("mouseenter", function () {
      hovering = true;
      card.classList.add("tilt-active");
    });
    card.addEventListener("mousemove", function (e) {
      var rect = card.getBoundingClientRect();
      targetX = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
      targetY = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
      if (!raf) raf = requestAnimationFrame(update);
    });
    card.addEventListener("mouseleave", function () {
      hovering = false;
      targetX = 0;
      targetY = 0;
      card.classList.remove("tilt-active");
      if (!raf) raf = requestAnimationFrame(update);
    });
  });
})();
</script>
