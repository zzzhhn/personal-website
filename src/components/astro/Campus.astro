---
import { UI } from "../../lib/i18n";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
  <div class="mx-auto" style="max-width: var(--max-width-content);">
    <SectionHeading variant="numbered" number="05" titleEn={UI.sections.campus.en} titleZh={UI.sections.campus.zh} />

    <div class="space-y-6 mx-auto" style="max-width: 48rem;">
      {UI.campus.map((entry) => (
        <div class="card-outline p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
            <div>
              <h3 class="text-lg font-semibold" style="color: var(--color-text-primary);">
                <span data-lang="en" style="font-family: 'Times New Roman', Times, serif;">{entry.role.en}</span>
                <span data-lang="zh" style="font-family: 'Kaiti SC', 'STKaiti', 'KaiTi', serif;">{entry.role.zh}</span>
              </h3>
              <p class="text-sm mt-1" style="color: var(--color-text-secondary);">
                <span data-lang="en">{entry.org.en}</span>
                <span data-lang="zh">{entry.org.zh}</span>
              </p>
            </div>
            <span class="glass-subtle px-3 py-1 text-xs font-medium" style="color: var(--color-text-secondary);">
              <span data-lang="en">{entry.period.en}</span>
              <span data-lang="zh">{entry.period.zh}</span>
            </span>
          </div>

          <!-- EN items -->
          <ul data-lang="en" class="space-y-3">
            {entry.items.en.map((item) => (
              <li class="text-sm flex items-start gap-2.5" style="color: var(--color-text-secondary);">
                <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                <span><strong style="color: var(--color-text-primary);">{item.label}:</strong> {item.text}</span>
              </li>
            ))}
          </ul>
          <!-- ZH items -->
          <ul data-lang="zh" class="space-y-3">
            {entry.items.zh.map((item) => (
              <li class="text-sm flex items-start gap-2.5" style="color: var(--color-text-secondary);">
                <span class="mt-1.5 w-1 h-1 rounded-full flex-shrink-0" style="background: var(--color-accent);" />
                <span><strong style="color: var(--color-text-primary);">{item.label}：</strong>{item.text}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
