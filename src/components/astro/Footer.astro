---
import { SITE } from "../../lib/constants";
---

<footer class="border-t px-6 py-12" style="border-color: var(--color-border-subtle);">
  <div class="mx-auto text-center" style="max-width: var(--max-width-content);">
    <p class="text-sm mb-2" style="color: var(--color-text-secondary);">
      Information on this site may not reflect the most recent updates.
      For the latest details, please contact me at
      <a
        href={`mailto:${SITE.email}`}
        class="underline transition-colors"
        style="color: var(--color-accent);"
      >
        {SITE.email}
      </a>.
    </p>
    <p class="text-sm" style="color: var(--color-text-secondary);">
      &copy; {new Date().getFullYear()} {SITE.name}. Built with Astro.
    </p>
  </div>
</footer>
