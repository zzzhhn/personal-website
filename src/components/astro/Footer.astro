---
import { SITE } from "../../lib/constants";
import { UI } from "../../lib/i18n";
---

<footer class="px-6 py-12" style="border-top: 1px solid var(--color-border-glass);">
  <div class="mx-auto text-center" style="max-width: var(--max-width-content);">
    <p class="text-sm mb-2" style="color: var(--color-text-tertiary);">
      <span data-lang="en">{UI.footer.disclaimer.en}</span>
      <span data-lang="zh">{UI.footer.disclaimer.zh}</span>
      {" "}
      <a
        href={`mailto:${SITE.email}`}
        class="underline transition-colors"
        style="color: var(--color-accent);"
      >
        {SITE.email}
      </a>.
    </p>
    <p class="text-sm" style="color: var(--color-text-tertiary);">
      &copy; {new Date().getFullYear()} {SITE.name}
    </p>
  </div>
</footer>
