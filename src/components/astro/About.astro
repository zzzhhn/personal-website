---
import { UI } from "../../lib/i18n";
import SectionHeading from "./SectionHeading.astro";
import BioProximity from "../react/BioProximity";
---

<section id="about" class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
  <div class="mx-auto" style="max-width: var(--max-width-content);">
    <SectionHeading variant="editorial" number="01" titleEn={UI.sections.about.en} titleZh={UI.sections.about.zh} />

    <div class="mx-auto mb-16 text-lg leading-relaxed" style="max-width: 40rem; color: var(--color-text-secondary);">
      <BioProximity textEn={UI.about.bio.en} textZh={UI.about.bio.zh} client:visible />
    </div>

    <!-- EN tech categories -->
    <div data-lang="en" class="skill-grid mx-auto" style="max-width: 56rem;">
      {UI.about.techCategories.en.map((cat, i) => {
        const foilKeys = ["code", "office", "ai", "data", "finance"];
        return (
          <div class="card-outline p-6 fade-up stagger-child skill-card" data-foil={foilKeys[i]} style={`--stagger-index: ${i};`}>
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">{cat.label}</h3>
            <div class="skill-scroll">
              <ul class="space-y-2.5">
                {cat.items.map((item) => (
                  <li class="text-sm" style="color: var(--color-text-secondary);">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>

    <!-- ZH tech categories -->
    <div data-lang="zh" class="skill-grid mx-auto" style="max-width: 56rem;">
      {UI.about.techCategories.zh.map((cat, i) => {
        const foilKeys = ["code", "office", "ai", "data", "finance"];
        return (
          <div class="card-outline p-6 fade-up stagger-child skill-card" data-foil={foilKeys[i]} style={`--stagger-index: ${i};`}>
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">{cat.label}</h3>
            <div class="skill-scroll">
              <ul class="space-y-2.5">
                {cat.items.map((item) => (
                  <li class="text-sm" style="color: var(--color-text-secondary);">{item}</li>
                ))}
              </ul>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
/* ── Foil watermark: floats behind card, extends beyond edges ── */
[data-foil]::before {
  content: "";
  position: absolute;
  inset: -40%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 0.25s ease-out, transform 0.35s ease;
  pointer-events: none;
  z-index: 0;
  /* Soft radial fade so edges dissolve naturally */
  -webkit-mask-image: radial-gradient(ellipse at center, black 50%, transparent 85%);
  mask-image: radial-gradient(ellipse at center, black 50%, transparent 85%);
}
[data-foil]:hover::before {
  opacity: 0.4;
  transform: scale(1);
}
[data-foil] > * { position: relative; z-index: 1; }

