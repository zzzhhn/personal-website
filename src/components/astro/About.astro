---
import { UI } from "../../lib/i18n";
import SectionHeading from "./SectionHeading.astro";
---

<section id="about" class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
  <div class="mx-auto" style="max-width: var(--max-width-content);">
    <SectionHeading variant="editorial" number="01" titleEn={UI.sections.about.en} titleZh={UI.sections.about.zh} />

    <div class="bio-kinetic mx-auto mb-16 text-lg leading-relaxed text-center" style="max-width: 40rem; color: var(--color-text-secondary);">
      <p data-lang="en" class="bio-text">{UI.about.bio.en}</p>
      <p data-lang="zh" class="bio-text">{UI.about.bio.zh}</p>
    </div>

    <!-- EN tech categories -->
    <div data-lang="en" class="grid grid-cols-2 md:grid-cols-4 gap-5 mx-auto" style="max-width: 56rem;">
      {UI.about.techCategories.en.map((cat, i) => {
        const foilKeys = ["code", "data", "finance", "tools"];
        return (
          <div class="card-outline p-6 fade-up stagger-child" data-foil={foilKeys[i]} style={`--stagger-index: ${i};`}>
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">{cat.label}</h3>
            <ul class="space-y-2.5">
              {cat.items.map((item) => (
                <li class="text-sm" style="color: var(--color-text-secondary);">{item}</li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>

    <!-- ZH tech categories -->
    <div data-lang="zh" class="grid grid-cols-2 md:grid-cols-4 gap-5 mx-auto" style="max-width: 56rem;">
      {UI.about.techCategories.zh.map((cat, i) => {
        const foilKeys = ["code", "data", "finance", "tools"];
        return (
          <div class="card-outline p-6 fade-up stagger-child" data-foil={foilKeys[i]} style={`--stagger-index: ${i};`}>
            <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-accent);">{cat.label}</h3>
            <ul class="space-y-2.5">
              {cat.items.map((item) => (
                <li class="text-sm" style="color: var(--color-text-secondary);">{item}</li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style is:global>
/* ── Foil watermark: floats behind card, extends beyond edges ── */
[data-foil]::before {
  content: "";
  position: absolute;
  inset: -40%;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  opacity: calc(var(--glow) * 0.3);
  transform: scale(calc(0.95 + var(--glow) * 0.05));
  transition: opacity 0.4s ease, transform 0.4s ease;
  pointer-events: none;
  z-index: 0;
  /* Soft radial fade so edges dissolve naturally */
  -webkit-mask-image: radial-gradient(ellipse at center, black 50%, transparent 85%);
  mask-image: radial-gradient(ellipse at center, black 50%, transparent 85%);
}
[data-foil] > * { position: relative; z-index: 1; }

/* Dark/silver SVGs */
