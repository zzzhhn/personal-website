/* ── 5-card grid: all in one row on desktop ── */
.skill-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1.25rem;
}
@media (max-width: 767px) {
  .skill-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .skill-grid > :nth-child(5) {
    grid-column: 1 / -1;
    max-width: calc(50% - 0.625rem);
    justify-self: center;
  }
}

/* ── Skill card scrollable area ── */
.skill-card {
  display: flex;
  flex-direction: column;
}
.skill-scroll {
  flex: 1;
  overflow-y: auto;
  max-height: 10rem;
  scrollbar-width: thin;
  scrollbar-color: var(--skill-scroll-thumb) var(--skill-scroll-track);
  padding-right: 0.25rem;

  --skill-scroll-thumb: oklch(0.45 0.01 255 / 0.5);
  --skill-scroll-track: oklch(0.3 0.008 255 / 0.2);
}
:global([data-theme="light"]) .skill-scroll {
  --skill-scroll-thumb: oklch(0.55 0.015 60 / 0.45);
  --skill-scroll-track: oklch(0.75 0.01 60 / 0.15);
}
.skill-scroll::-webkit-scrollbar {
  width: 4px;
}
.skill-scroll::-webkit-scrollbar-thumb {
  background: var(--skill-scroll-thumb);
  border-radius: 4px;
}
.skill-scroll::-webkit-scrollbar-track {
  background: var(--skill-scroll-track);
  border-radius: 4px;
}

</style>
