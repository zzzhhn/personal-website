.8'/%3E%3Ccircle cx='55' cy='108' r='2' stroke='url(%23g)' stroke-width='0.8'/%3E%3Cline x1='62' y1='52' x2='62' y2='114' stroke='url(%23g)' stroke-width='0.6' stroke-dasharray='2 2'/%3E%3C/svg%3E"); }

/* ── Bio kinetic: faux-bold + sliding underline bar ── */
.bio-kinetic { position: relative; }
.bw {
  display: inline;
  transition: text-shadow 0.25s ease-out;
}
.bio-ul-bar {
  position: absolute;
  height: 1.5px;
  /* Tapered: bright center, fades to transparent at tips */
  background: radial-gradient(ellipse at center, var(--color-accent) 0%, transparent 100%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.25s ease-out;
}
</style>

<script is:inline>
(function () {
  var container = document.querySelector(".bio-kinetic");
  if (!container) return;
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

  /* Underline bar — single element, animated via CSS transitions */
  var bar = document.createElement("div");
  bar.className = "bio-ul-bar";
  container.appendChild(bar);

  function getVisibleBio() {
    var lang = document.documentElement.getAttribute("data-site-lang") || "en";
    var texts = container.querySelectorAll(".bio-text");
    for (var i = 0; i < texts.length; i++) {
      if (texts[i].getAttribute("data-lang") === lang) return texts[i];
    }
    return texts[0];
  }

  function splitBio(p) {
    if (p.querySelector(".bw")) return;
    var lang = p.getAttribute("data-lang");
    var raw = p.textContent || "";
    p.textContent = "";
    if (lang === "zh") {
      for (var i = 0; i < raw.length; i++) {
        var s = document.createElement("span");
        s.className = "bw";
        s.textContent = raw[i];
        p.appendChild(s);
      }
    } else {
      var tokens = raw.split(/(\s+)/);
      for (var j = 0; j < tokens.length; j++) {
        var tok = tokens[j];
        if (!tok) continue;
        if (/^\s+$/.test(tok)) {
          var prev = p.lastElementChild;
          if (prev && prev.classList.contains("bw")) {
            prev.textContent += tok;
          } else {
            p.appendChild(document.createTextNode(tok));
          }
        } else {
          var w = document.createElement("span");
          w.className = "bw";
          w.textContent = tok;
          p.appendChild(w);
        }
      }
    }
  }

  var pending = false;
  var mouseX = -9999;
  var mouseY = -9999;
  var isInside = false;
  var RADIUS = 70; /* px — visible underline half-width from cursor */
  var SIGMA = 50;
  var SIG2 = 2 * SIGMA * SIGMA;

  /* Smooth bar state — lerped each frame for fluid animation */
  var barState = { left: 0, width: 0, top: 0, opacity: 0 };
  var barTarget = { left: 0, width: 0, top: 0, opacity: 0 };
  var LERP = 0.18; /* interpolation speed per frame */

  function lerp(a, b, t) { return a + (b - a) * t; }

  function update() {
    pending = false;
    var p = getVisibleBio();
    if (!p) return;
    splitBio(p);
    var spans = p.querySelectorAll(".bw");
    var cRect = container.getBoundingClientRect();

    /* Reset all text-shadow */
    for (var i = 0; i < spans.length; i++) {
      spans[i].style.textShadow = "";
    }

    if (!isInside) {
      barTarget.opacity = 0;
    } else {
      /* Find which line the mouse is on */
      var lineBottom = 0;
      var onLine = false;
      var tolerance = 6;
      for (var i = 0; i < spans.length; i++) {
        var r = spans[i].getBoundingClientRect();
        if (r.width === 0) continue;
        var rowY = r.top + r.height / 2;
        if (Math.abs(mouseY - rowY) < r.height / 2 + tolerance) {
          onLine = true;
          lineBottom = r.bottom;
          /* Apply faux-bold based on horizontal distance */
          var cx = r.left + r.width / 2;
          var dx = mouseX - cx;
          var t = Math.exp(-(dx * dx) / SIG2);
          if (t > 0.1) {
            spans[i].style.textShadow = "0 0 " + (t * 0.5).toFixed(2) + "px currentColor";
          }
        }
      }

      if (onLine) {
        /* Bar extent driven directly by cursor ± RADIUS, not by word boundaries */
        barTarget.left = mouseX - RADIUS - cRect.left;
        barTarget.width = RADIUS * 2;
        barTarget.top = lineBottom - cRect.top + 2;
        barTarget.opacity = 0.55;
      } else {
        barTarget.opacity = 0;
      }
    }

    /* Lerp bar state toward target for fluid motion */
    barState.left = lerp(barState.left, barTarget.left, LERP);
    barState.width = lerp(barState.width, barTarget.width, LERP);
    barState.top = lerp(barState.top, barTarget.top, LERP);
    barState.opacity = lerp(barState.opacity, barTarget.opacity, barTarget.opacity > barState.opacity ? LERP : 0.12);

    bar.style.left = barState.left.toFixed(1) + "px";
    bar.style.width = barState.width.toFixed(1) + "px";
    bar.style.top = barState.top.toFixed(1) + "px";
    bar.style.opacity = barState.opacity.toFixed(3);

    /* Keep animating if not settled */
    if (Math.abs(barState.opacity - barTarget.opacity) > 0.005 ||
        Math.abs(barState.left - barTarget.left) > 0.5 ||
        Math.abs(barState.width - barTarget.width) > 0.5 ||
        Math.abs(barState.top - barTarget.top) > 0.5) {
      pending = true;
      requestAnimationFrame(update);
    }
  }

  container.addEventListener("mousemove", function (e) {
    mouseX = e.clientX;
    mouseY = e.clientY;
    isInside = true;
    if (!pending) { pending = true; requestAnimationFrame(update); }
  });
  container.addEventListener("mouseleave", function () {
    isInside = false;
    if (!pending) { pending = true; requestAnimationFrame(update); }
  });

  var obs = new MutationObserver(function () {
    var p = getVisibleBio();
    if (p && !p.querySelector(".bw")) splitBio(p);
  });
  obs.observe(document.documentElement, { attributes: true, attributeFilter: ["data-site-lang"] });
})();
</script>
