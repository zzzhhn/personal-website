---
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";
import { UI } from "../../lib/i18n";
---

<header class="fixed top-0 left-0 right-0 z-50 header-glass">
  <nav class="mx-auto flex items-center justify-between px-6 py-3" style="max-width: var(--max-width-content);">
    <a href="/" class="logo-mark" style="text-decoration: none;" aria-label="Home">
      <img src="/images/logo-gold.png" alt="HZ." class="logo-img logo-light" width="50" height="24" loading="eager" />
      <img src="/images/logo-silver.png" alt="HZ." class="logo-img logo-dark" width="50" height="24" loading="eager" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {Object.entries(UI.nav).map(([_key, val]) => (
        <a
          href={`#${_key}`}
          class="nav-pill text-sm font-medium px-3 py-1.5 rounded-lg transition-all"
          style="text-decoration: none;"
        >
          <span data-lang="en">{val.en}</span>
          <span data-lang="zh">{val.zh}</span>
        </a>
      ))}
      <div class="w-px h-4 mx-2" style="background: var(--color-border-subtle);" />
      <LangToggle />
      <ThemeToggle />
    </div>

    <!-- Mobile controls -->
    <div class="flex sm:hidden items-center gap-1.5">
      <LangToggle />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        class="p-2 rounded-lg transition-colors cursor-pointer"
        style="background: transparent; color: var(--color-text-secondary);"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden sm:hidden px-6 pb-4">
    {Object.entries(UI.nav).map(([_key, val]) => (
      <a
        href={`#${_key}`}
        class="block py-2.5 text-sm font-medium transition-colors nav-pill mobile-nav-link"
        style="text-decoration: none;"
      >
        <span data-lang="en">{val.en}</span>
        <span data-lang="zh">{val.zh}</span>
      </a>
    ))}
  </div>
</header>

<style>
  .header-glass {
    background: var(--color-surface-elevated);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--color-border-glass);
    box-shadow:
      0 8px 32px var(--color-shadow-depth),
      inset 0 1px 0 var(--color-inset-highlight);
  }

  .logo-mark {
    display: flex;
    align-items: center;
  }
  .logo-img {
    height: 24px;
    width: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }
  /* Default (dark theme): show silver, hide gold */
  .logo-light { display: none; }
  .logo-dark  { display: block; }
  /* Light theme: show gold, hide silver */
  :global([data-theme="light"]) .logo-light { display: block; }
  :global([data-theme="light"]) .logo-dark  { display: none; }

  .logo-mark:hover .logo-img {
    filter: brightness(1.15);
  }

  .nav-pill {
    color: var(--color-text-secondary);
  }
  .nav-pill:hover {
    color: var(--color-text-primary);
    background: var(--color-glow-ambient);
  }
  .nav-pill.active {
    color: var(--color-text-primary);
    background: oklch(0.68 0.16 255 / 0.1);
  }

  #mobile-menu-btn:hover {
    background: var(--color-glow-ambient) !important;
    color: var(--color-text-primary) !important;
  }
</style>

<script is:inline>
  (function () {
    if (window.__mobileMenuInit) return;
    window.__mobileMenuInit = true;
    document.addEventListener("click", function (e) {
      var btn = e.target.closest("#mobile-menu-btn");
      if (btn) {
        var menu = document.getElementById("mobile-menu");
        if (menu) menu.classList.toggle("hidden");
        return;
      }
      var link = e.target.closest(".mobile-nav-link");
      if (link) {
        var menu = document.getElementById("mobile-menu");
        if (menu) menu.classList.add("hidden");
      }
    });
    // Smooth scroll for nav anchor links (not on page load)
    document.addEventListener("click", function (e) {
      var anchor = e.target.closest('a[href^="#"]');
      if (anchor) {
        var target = document.querySelector(anchor.getAttribute("href"));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth" });
        }
      }
    });

    // Scroll spy: highlight active nav link based on visible section
    var sections = document.querySelectorAll("section[id]");
    if (sections.length > 0) {
      var navLinks = document.querySelectorAll('.nav-pill[href^="#"]');
      var spyObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var id = entry.target.getAttribute("id");
            navLinks.forEach(function (link) {
              if (link.getAttribute("href") === "#" + id) {
                link.classList.add("active");
              } else {
                link.classList.remove("active");
              }
            });
          }
        });
      }, { rootMargin: "-20% 0px -70% 0px" });
      sections.forEach(function (s) { spyObs.observe(s); });
    }
  })();
</script>
