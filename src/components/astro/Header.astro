---
import ThemeToggle from "./ThemeToggle.astro";
import { NAV_ITEMS } from "../../lib/constants";
---

<header
  class="fixed top-0 left-0 right-0 z-50 glass"
  style="border-radius: 0; border-top: none; border-left: none; border-right: none;"
>
  <nav class="mx-auto flex items-center justify-between px-6 py-4" style="max-width: var(--max-width-content);">
    <a href="/" class="text-lg font-semibold tracking-tight" style="color: var(--color-text-primary); text-decoration: none;">
      HZ
    </a>

    <div class="flex items-center gap-6">
      {NAV_ITEMS.map((item) => (
        <a
          href={item.href}
          class="text-sm font-medium transition-colors hidden sm:block"
          style={`color: var(--color-text-secondary); text-decoration: none;`}
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header a:hover {
    color: var(--color-text-primary) !important;
  }
</style>
