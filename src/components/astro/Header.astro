---
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";
import { UI } from "../../lib/i18n";
---

<header class="fixed top-0 left-0 right-0 z-50 header-glass">
  <nav class="mx-auto flex items-center justify-between px-6 py-3" style="max-width: var(--max-width-content);">
    <a href="/" class="logo-mark" style="text-decoration: none;" aria-label="Home">
      <svg class="logo-svg" viewBox="0 0 48 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Gold foil gradient (light mode default) -->
          <linearGradient id="foil-grad" x1="0" y1="0" x2="48" y2="28" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#C9A84C" />
            <stop offset="25%" stop-color="#F0D78C" />
            <stop offset="50%" stop-color="#C9A84C" />
            <stop offset="75%" stop-color="#F0D78C" />
            <stop offset="100%" stop-color="#B8943F" />
          </linearGradient>
          <!-- Shimmer sweep -->
          <linearGradient id="foil-shimmer" x1="-48" y1="0" x2="0" y2="28" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="transparent" />
            <stop offset="45%" stop-color="transparent" />
            <stop offset="50%" stop-color="rgba(255,255,255,0.6)" />
            <stop offset="55%" stop-color="transparent" />
            <stop offset="100%" stop-color="transparent" />
          </linearGradient>
        </defs>
        <!-- H letterform — thin line strokes -->
        <path d="M4 3 L4 25" stroke="url(#foil-grad)" stroke-width="1.6" stroke-linecap="round" />
        <path d="M4 14 L16 14" stroke="url(#foil-grad)" stroke-width="1.6" stroke-linecap="round" />
        <path d="M16 3 L16 25" stroke="url(#foil-grad)" stroke-width="1.6" stroke-linecap="round" />
        <!-- Z letterform -->
        <path d="M22 5 L36 5 L22 23 L36 23" stroke="url(#foil-grad)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
        <!-- Period dot -->
        <circle cx="42" cy="23" r="1.8" fill="url(#foil-grad)" />
        <!-- Shimmer overlay layer -->
        <rect class="logo-shimmer" x="0" y="0" width="48" height="28" fill="url(#foil-shimmer)" />
      </svg>
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {Object.entries(UI.nav).map(([_key, val]) => (
        <a
          href={`#${_key}`}
          class="nav-pill text-sm font-medium px-3 py-1.5 rounded-lg transition-all"
          style="text-decoration: none;"
        >
          <span data-lang="en">{val.en}</span>
          <span data-lang="zh">{val.zh}</span>
        </a>
      ))}
      <div class="w-px h-4 mx-2" style="background: var(--color-border-subtle);" />
      <LangToggle />
      <ThemeToggle />
    </div>

    <!-- Mobile controls -->
    <div class="flex sm:hidden items-center gap-1.5">
      <LangToggle />
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        class="p-2 rounded-lg transition-colors cursor-pointer"
        style="background: transparent; color: var(--color-text-secondary);"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden sm:hidden px-6 pb-4">
    {Object.entries(UI.nav).map(([_key, val]) => (
      <a
        href={`#${_key}`}
        class="block py-2.5 text-sm font-medium transition-colors nav-pill mobile-nav-link"
        style="text-decoration: none;"
      >
        <span data-lang="en">{val.en}</span>
        <span data-lang="zh">{val.zh}</span>
      </a>
    ))}
  </div>
</header>

<style>
  .header-glass {
    background: var(--color-surface-glass);
    backdrop-filter: blur(60px) saturate(2);
    -webkit-backdrop-filter: blur(60px) saturate(2);
    border-bottom: 1px solid var(--color-border-glass);
    box-shadow:
      0 1px 0 0 var(--color-specular),
      0 4px 24px oklch(0 0 0 / 0.08);
  }

  .logo-mark {
    display: flex;
    align-items: center;
  }
  .logo-svg {
    width: 42px;
    height: 24px;
  }

  /* Shimmer sweep animation on hover */
  .logo-shimmer {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .logo-mark:hover .logo-shimmer {
    opacity: 1;
    animation: foil-sweep 0.8s ease-out forwards;
  }
  @keyframes foil-sweep {
    from { transform: translateX(-48px); }
    to   { transform: translateX(48px); }
  }

  /* Dark mode: gold → silver (CSS on SVG stops) */
  :global([data-theme="dark"]) #foil-grad stop:nth-child(1) { stop-color: #9CA3AF; }
  :global([data-theme="dark"]) #foil-grad stop:nth-child(2) { stop-color: #E5E7EB; }
  :global([data-theme="dark"]) #foil-grad stop:nth-child(3) { stop-color: #9CA3AF; }
  :global([data-theme="dark"]) #foil-grad stop:nth-child(4) { stop-color: #E5E7EB; }
  :global([data-theme="dark"]) #foil-grad stop:nth-child(5) { stop-color: #6B7280; }

  .nav-pill {
    color: var(--color-text-secondary);
  }
  .nav-pill:hover {
    color: var(--color-text-primary);
    background: var(--color-glow-ambient);
  }
  .nav-pill.active {
    color: var(--color-text-primary);
    background: oklch(0.68 0.16 255 / 0.1);
  }

  #mobile-menu-btn:hover {
    background: var(--color-glow-ambient) !important;
    color: var(--color-text-primary) !important;
  }
</style>

<script is:inline>
  (function () {
    if (window.__mobileMenuInit) return;
    window.__mobileMenuInit = true;
    document.addEventListener("click", function (e) {
      var btn = e.target.closest("#mobile-menu-btn");
      if (btn) {
        var menu = document.getElementById("mobile-menu");
        if (menu) menu.classList.toggle("hidden");
        return;
      }
      var link = e.target.closest(".mobile-nav-link");
      if (link) {
        var menu = document.getElementById("mobile-menu");
        if (menu) menu.classList.add("hidden");
      }
    });
    // Smooth scroll for nav anchor links (not on page load)
    document.addEventListener("click", function (e) {
      var anchor = e.target.closest('a[href^="#"]');
      if (anchor) {
        var target = document.querySelector(anchor.getAttribute("href"));
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth" });
        }
      }
    });

    // Scroll spy: highlight active nav link based on visible section
    var sections = document.querySelectorAll("section[id]");
    if (sections.length > 0) {
      var navLinks = document.querySelectorAll('.nav-pill[href^="#"]');
      var spyObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            var id = entry.target.getAttribute("id");
            navLinks.forEach(function (link) {
              if (link.getAttribute("href") === "#" + id) {
                link.classList.add("active");
              } else {
                link.classList.remove("active");
              }
            });
          }
        });
      }, { rootMargin: "-20% 0px -70% 0px" });
      sections.forEach(function (s) { spyObs.observe(s); });
    }
    // Logo foil: sync gradient to theme (JS fallback for SVG stop-color)
    var gold = ["#C9A84C","#F0D78C","#C9A84C","#F0D78C","#B8943F"];
    var silver = ["#9CA3AF","#E5E7EB","#9CA3AF","#E5E7EB","#6B7280"];
    function syncLogoFoil() {
      var isDark = document.documentElement.getAttribute("data-theme") === "dark";
      var colors = isDark ? silver : gold;
      var stops = document.querySelectorAll("#foil-grad stop");
      stops.forEach(function (s, i) { if (colors[i]) s.setAttribute("stop-color", colors[i]); });
    }
    syncLogoFoil();
    new MutationObserver(syncLogoFoil).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
  })();
</script>
