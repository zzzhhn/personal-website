---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/astro/Hero.astro";
import About from "../components/astro/About.astro";
import Education from "../components/astro/Education.astro";
import Campus from "../components/astro/Campus.astro";
import Contact from "../components/astro/Contact.astro";
import ExperienceTimeline from "../components/react/ExperienceTimeline";
import ProjectDeck from "../components/react/ProjectDeck";
import { getCollection } from "astro:content";
import SectionHeading from "../components/astro/SectionHeading.astro";
import { SITE } from "../lib/constants";
import { UI, EXPERIENCES } from "../lib/i18n";

// Build bilingual experience array
const bilingualExperiences = EXPERIENCES.en.map((enExp, i) => ({
  en: {
    role: enExp.role,
    organization: enExp.organization,
    location: enExp.location,
    type: enExp.type,
    highlights: [...enExp.highlights],
    techStack: [...enExp.techStack],
  },
  zh: {
    role: EXPERIENCES.zh[i].role,
    organization: EXPERIENCES.zh[i].organization,
    location: EXPERIENCES.zh[i].location,
    type: EXPERIENCES.zh[i].type,
    highlights: [...EXPERIENCES.zh[i].highlights],
    techStack: [...EXPERIENCES.zh[i].techStack],
  },
  startDate: enExp.startDate,
  endDate: enExp.endDate,
}));

// Fetch and sort projects (featured first, then by order)
const rawProjects = await getCollection("projects");
const projects = rawProjects
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return a.data.order - b.data.order;
  })
  .map((p) => ({
    title: p.data.title,
    slug: p.data.slug,
    tagline: p.data.tagline,
    description: p.data.description,
    status: p.data.status,
    techStack: p.data.techStack,
    highlights: p.data.highlights ?? [],
    links: p.data.links,
  }));
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <Hero />
  <About />
  <Education />

  <section id="experience" class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
    <div class="mx-auto" style="max-width: var(--max-width-content);">
      <SectionHeading variant="numbered" number="03" titleEn={UI.sections.experience.en} titleZh={UI.sections.experience.zh} />
      <div class="mx-auto" style="max-width: 48rem;">
        <ExperienceTimeline client:visible experiences={bilingualExperiences} />
      </div>
    </div>
  </section>

  <section id="projects" class="section-glow px-6" style={`padding-top: var(--spacing-section); padding-bottom: var(--spacing-section);`}>
    <div class="mx-auto" style="max-width: var(--max-width-content);">
      <SectionHeading variant="numbered" number="04" titleEn={UI.sections.projects.en} titleZh={UI.sections.projects.zh} />
      <ProjectDeck client:visible projects={projects} />
    </div>
  </section>

  <Campus />
  <Contact />
</BaseLayout>
